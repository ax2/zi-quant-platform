# Local PostgreSQL database for ZiQuant.
DATABASE_URL=postgresql+asyncpg://zi_quant:change_me@127.0.0.1:5432/zi_quant
HOST=127.0.0.1
PORT=8092
AUTO_CREATE_SCHEMA=true
ZI_API_TOKEN=
QVERIS_DATA_API_KEY=
QVERIS_BASE_URL=https://qveris.ai/api/v1
QVERIS_PREPARED_SEARCH_ID=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=120
GITHUB_TOKEN=
LARK_CLI_BIN=lark-cli
LARK_SIGNAL_CHAT_ID=oc_68db16641907e192c8cfd23e55d6c1ac
LARK_SIGNAL_LIVE_ENABLED=false
LARK_SIGNAL_DEFAULT_DRY_RUN=true

# Production data-quality gates. Raise these values before a production launch
# when you want readiness to require broader real-data coverage.
MIN_PUBLIC_POOL_REAL_BAR_COVERAGE=0.10
MIN_PUBLIC_POOL_LONG_HISTORY_COVERAGE=0.10
MIN_PUBLIC_POOL_FINANCIAL_COVERAGE=0.06
MIN_PUBLIC_POOL_REAL_BAR_SYMBOLS=30
MIN_PUBLIC_POOL_LONG_HISTORY_SYMBOLS=30
MIN_PUBLIC_POOL_FINANCIAL_SYMBOLS=30
MAX_FALLBACK_BAR_RATIO=0.05
